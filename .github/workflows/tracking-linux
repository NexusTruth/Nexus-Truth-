name: Build Nexus Truth Worker

on:
  push:
    branches: [ main ]

jobs:
  windows_job:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    
    - name: Initialize Go Environment
      uses: actions/setup-go@v5
      with:
        go-version: '1.22'
        
    - name: Compile Windows Administrator Executable
      env:
        GOOS: windows
        GOARCH: amd64
      run: go build -o worker.exe main.go
      
    - name: Save Windows Executable
      uses: actions/upload-artifact@v4
      with:
        name: windows-distribution
        path: worker.exe

  linux_job:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    
    - name: Initialize Go Environment
      uses: actions/setup-go@v5
      with:
        go-version: '1.22'

    - name: Make Build Scripts Executable
      run: chmod +x build.sh

    - name: Run Linux AppImage Packager
      run: ./build.sh
      
    - name: Save Linux AppImage
      uses: actions/upload-artifact@v4
      with:
        name: linux-distribution
        path: dist/*
