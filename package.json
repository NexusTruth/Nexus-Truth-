{
  "name": "nexus-truth-client",
  "version": "1.0.0",
  "description": "Nexus Truth Idle Computing Client",
  "main": "main.cjs",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "package-mac": "electron-packager . NexusTruth --platform=darwin --arch=x64 --out=dist/",
    "package-win": "electron-packager . NexusTruth --platform=win32 --arch=x64 --out=dist/",
    "package-linux": "electron-packager . NexusTruth --platform=linux --arch=x64 --out=dist/",
    "build-win": "electron-builder --win"
  },
  "build": {
    "appId": "com.nexustruth.client",
    "win": {
      "requestedExecutionLevel": "requireAdministrator",
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "systeminformation": "^5.31.7"
  }
}
